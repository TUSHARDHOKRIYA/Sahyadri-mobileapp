<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp"
    tools:context=".ui.medical.billing.BillPreviewActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/receiptCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏥 MedFoundation"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Empowering Health, Saving Lives"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/grey_200" />

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TableRow android:layout_marginBottom="4dp">
                    <TextView android:text="Bill No:" android:textSize="12sp" android:textColor="@color/grey_400"/>
                    <TextView android:id="@+id/billNoText" android:layout_marginStart="8dp" android:text="MED-MP-20250310-001" android:textSize="12sp" android:textStyle="bold"/>
                </TableRow>
                <TableRow android:layout_marginBottom="4dp">
                    <TextView android:text="Date:" android:textSize="12sp" android:textColor="@color/grey_400"/>
                    <TextView android:id="@+id/dateText" android:layout_marginStart="8dp" android:text="10 Mar 2025" android:textSize="12sp"/>
                </TableRow>
                <TableRow android:layout_marginBottom="4dp">
                    <TextView android:text="Medical:" android:textSize="12sp" android:textColor="@color/grey_400"/>
                    <TextView android:text="MedPlus Pharmacy" android:layout_marginStart="8dp" android:textSize="12sp"/>
                </TableRow>
                <TableRow android:layout_marginBottom="4dp">
                    <TextView android:text="Patient:" android:textSize="12sp" android:textColor="@color/grey_400"/>
                    <TextView android:id="@+id/patientNameText" android:layout_marginStart="8dp" android:text="Rajesh Sharma" android:textSize="12sp"/>
                </TableRow>
                <TableRow android:layout_marginBottom="4dp">
                    <TextView android:text="Card ID:" android:textSize="12sp" android:textColor="@color/grey_400"/>
                    <TextView android:text="MEDF-2025-00142" android:layout_marginStart="8dp" android:textSize="12sp"/>
                </TableRow>
            </TableLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/grey_200" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total Amount:"/>
                <TextView android:id="@+id/totalAmountText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹ 1,000.00"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Discount (25%):" android:textColor="@color/secondary"/>
                <TextView android:id="@+id/discountAmountText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="- ₹ 250.00" android:textColor="@color/secondary"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/grey_200" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Amount Payable:" android:textStyle="bold" android:textSize="18sp"/>
                <TextView android:id="@+id/payableAmountText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹ 750.00" android:textStyle="bold" android:textSize="18sp" android:textColor="@color/primary"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="✅ Payment Received"
                android:textColor="@color/secondary"
                android:textStyle="bold" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/shareBillBtn"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Share Bill"
        app:layout_constraintTop_toBottomOf="@id/receiptCard" />

    <Button
        android:id="@+id/doneBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="Done"
        app:layout_constraintTop_toBottomOf="@id/shareBillBtn" />

</androidx.constraintlayout.widget.ConstraintLayout>
