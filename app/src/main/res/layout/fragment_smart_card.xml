<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- Teal header band -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="E-Smart Card"
                android:textColor="@color/on_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Present QR at any partner pharmacy or hospital"
                android:textColor="@color/on_primary"
                android:textSize="12sp"
                android:alpha="0.80"
                android:gravity="center" />
        </LinearLayout>

        <!-- Card lifted into the header -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-28dp"
            android:layout_marginBottom="4dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="28dp">

                <!-- Foundation branding row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/cardLogo"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_launcher_foreground"
                        android:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MedFoundation"
                            android:textColor="@color/primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sahyadri Foundation"
                            android:textColor="@color/on_surface_dim"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Active chip -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/secondary_light"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="ACTIVE"
                        android:textColor="@color/secondary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="18dp"
                    android:background="@color/grey_200" />

                <!-- Card ID -->
                <TextView
                    android:id="@+id/cardId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEDF-2025-00142"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />

                <!-- Head Name -->
                <TextView
                    android:id="@+id/headName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Rajesh Sharma"
                    android:textColor="@color/on_surface_dim"
                    android:textSize="14sp" />

                <!-- Members & FY row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MEMBERS"
                            android:textColor="@color/on_surface_dim"
                            android:textSize="10sp"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/memberCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FINANCIAL YEAR"
                            android:textColor="@color/on_surface_dim"
                            android:textSize="10sp"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/fyYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2025–26"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VALID: "
                        android:textColor="@color/on_surface_dim"
                        android:textSize="11sp"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/validity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 Apr 2025 – 31 Mar 2026"
                        android:textColor="@color/on_surface"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- QR Code -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="10dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/grey_200"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/qrCode"
                            android:layout_width="180dp"
                            android:layout_height="180dp"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Scan at partner pharmacy counter"
                            android:textColor="@color/on_surface_dim"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Download & Share buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="28dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/downloadButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Download"
                android:textSize="14sp"
                app:cornerRadius="10dp"
                app:icon="@android:drawable/ic_menu_save" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shareButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Share"
                android:textSize="14sp"
                app:cornerRadius="10dp"
                app:icon="@android:drawable/ic_menu_share" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
