<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_patient"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.medfoundation.ui.patient.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_smart_card"
        android:name="com.medfoundation.ui.patient.smartcard.SmartCardFragment"
        android:label="Smart Card"
        tools:layout="@layout/fragment_smart_card" />

    <fragment
        android:id="@+id/navigation_history"
        android:name="com.medfoundation.ui.patient.history.HistoryFragment"
        android:label="History"
        tools:layout="@layout/fragment_history" />

    <fragment
        android:id="@+id/navigation_nearby"
        android:name="com.medfoundation.ui.patient.nearby.NearbyFragment"
        android:label="Nearby"
        tools:layout="@layout/fragment_nearby" />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.medfoundation.ui.patient.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />
</navigation>
