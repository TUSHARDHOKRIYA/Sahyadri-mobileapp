    android:id="@+id/nav_graph_admin"
    app:startDestination="@id/navigation_admin_dashboard">

    <fragment
        android:id="@+id/navigation_admin_dashboard"
        android:name="com.medfoundation.ui.admin.dashboard.AdminDashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_admin_dashboard" />

    <fragment
        android:id="@+id/navigation_admin_families"
