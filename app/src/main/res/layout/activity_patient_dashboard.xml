<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.patient.dashboard.PatientDashboardActivity">

    <!-- Fragment container -->
    <fragment
        android:id="@+id/nav_host_fragment_patient"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@id/nav_view_patient"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navGraph="@navigation/nav_graph_patient" />

    <!-- Bottom Navigation: clean white with teal selected state -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/nav_view_patient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="8dp"
        app:itemActiveIndicatorStyle="@android:style/Widget"
        app:itemIconTint="@color/nav_selector_patient"
        app:itemTextColor="@color/nav_selector_patient"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:menu="@menu/bottom_nav_menu_patient" />

</androidx.constraintlayout.widget.ConstraintLayout>
